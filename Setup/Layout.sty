\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{Setup/Layout}[2026/03/16 Page layout]

\geometry{
  inner=4.2cm,
  outer=4.2cm,
  top=2.7cm,
  bottom=3cm,
  marginparsep=0.5cm,
  includeheadfoot
}

% Calcola automaticamente la larghezza delle note in base al margine esterno disponibile,
% in modo che se cambi da a4paper a b5paper le note non escano dal foglio.
\setlength{\marginparwidth}{\dimexpr \evensidemargin + 1in - \marginparsep - 0.4cm \relax}

\setlength{\parindent}{1.5em}
\setlength{\parskip}{0pt}

\setlist[itemize]{itemsep=0.2em, topsep=0.4em}
\setlist[enumerate]{itemsep=0.2em, topsep=0.4em, label=(\arabic*)}

% ===================== Header & Footer Configuration =====================
\pagestyle{fancy}
\fancyhf{} % Clear default headers/footers

% Redefine chapter and section marks to be in mixed-case (not all-caps)
\renewcommand{\chaptermark}[1]{\markboth{Capitolo\ \thechapter.\ #1}{}}
\renewcommand{\sectionmark}[1]{\markright{\thesection.\ #1}}

% Header layout for twoside mode (aligned towards the page number on the outer margins):
% - Even pages (left page): page number and chapter title on outer edge (left)
% - Odd pages (right page): section title and page number on outer edge (right)
\fancyhead[EL]{\small{\normalfont\bfseries\thepage}\qquad\itshape\leftmark}
\fancyhead[ER]{}
\fancyhead[OL]{}
\fancyhead[OR]{\small\itshape\rightmark\qquad{\normalfont\bfseries\thepage}}

\renewcommand{\headrulewidth}{0.4pt} % Thin line under header
\renewcommand{\footrulewidth}{0pt}   % No line above footer

% Redefine 'plain' page style for chapter start pages and similar
\fancypagestyle{plain}{%
  \fancyhf{}% Clear all headers and footers
  \renewcommand{\headrulewidth}{0pt}% No line under header
  \renewcommand{\footrulewidth}{0pt}% No line above footer
}
