\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{Setup/Commands}[2026/03/16 Common math commands]

% Sets
\providecommand{\N}{\mathbb{N}}
\providecommand{\Z}{\mathbb{Z}}
\providecommand{\Q}{\mathbb{Q}}
\providecommand{\R}{\mathbb{R}}
\providecommand{\C}{\mathbb{C}}

% Short vector aliases that map directly to physics package commands.
\newcommand{\vva}{\vb{a}}
\newcommand{\vvb}{\vb{b}}
\newcommand{\vc}{\vb{c}}
\newcommand{\vh}{\vb{h}}
\newcommand{\vk}{\vb{k}}
\newcommand{\vvu}{\vb{u}}
\newcommand{\vv}{\vb{v}}
\newcommand{\vw}{\vb{w}}
\newcommand{\vx}{\vb{x}}
\newcommand{\vy}{\vb{y}}
\newcommand{\vz}{\vb{z}}
\newcommand{\vq}{\vb{q}}
\newcommand{\vp}{\vb{p}}
\newcommand{\vf}{\vb{f}}
\newcommand{\vF}{\vb{F}}
\newcommand{\vP}{\vb{P}}
\newcommand{\vG}{\vb{G}}
\newcommand{\vQ}{\vb{Q}}

% Definition equality.
\newcommand{\defeq}{\overset{\mathrm{def}}{=}}

% Compatibility alias for common typo.
\providecommand{\displaystile}{\displaystyle}

% Tensor symbols: bold sans-serif.
\newcommand{\tens}[1]{\boldsymbol{\mathsf{#1}}}

% Under-tilde notation (e.g. inertia tensor symbol).
\stackMath
\newcommand\tenq[2][1]{%
  \def\useanchorwidth{T}%
  \ifnum#1>1%
    \stackunder[0pt]{\tenq[\numexpr#1-1\relax]{#2}}{\scriptscriptstyle\sim}%
  \else%
    \stackunder[1pt]{#2}{\scriptscriptstyle\sim}%
  \fi%
}

% Real/imaginary parts as operators (override fraktur defaults).
\renewcommand{\Re}{\operatorname{Re}}
\renewcommand{\Im}{\operatorname{Im}}

% Author-only citation that still links to the bibliography entry.
\DeclareCiteCommand{\citeauthorlink}
  {}
  {\printtext[bibhyperref]{\printnames{labelname}}}
  {\multicitedelim}
  {}

% ===================== Streamlined margin notes =========================
% Tweaks (override before loading if you want)
\providecommand{\NoteFontSize}{\scriptsize}     % note text size
\providecommand{\NoteFont}{\itshape\sffamily}  % bold typewriter look
\providecommand{\NoteColor}{black}              % text color
\providecommand{\MarginNoteWidth}{3.0cm}        % box width

% Side-aware alignment helper (simplified for oneside)
\newcommand{\NoteAlign}{\raggedright}

% Single \note command. Optional argument vertically shifts the note.
\DeclareRobustCommand{\note}[2][0pt]{%
  \marginnote{%
    \NoteAlign\NoteFontSize\NoteFont\color{\NoteColor}%
    \ignorespaces#2%
  }[#1]%
}
% ======================================================================