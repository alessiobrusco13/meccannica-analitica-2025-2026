\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{Setup/Commands}[2026/03/16 Common math commands]

% Sets
\providecommand{\N}{\mathbb{N}}
\providecommand{\Z}{\mathbb{Z}}
\providecommand{\Q}{\mathbb{Q}}
\providecommand{\R}{\mathbb{R}}
\providecommand{\C}{\mathbb{C}}

% Short vector aliases that map directly to physics package commands.
\newcommand{\vva}{\vb{a}}
\newcommand{\vvb}{\vb{b}}
\newcommand{\vc}{\vb{c}}
\newcommand{\vh}{\vb{h}}
\newcommand{\vk}{\vb{k}}
\newcommand{\vvu}{\vb{u}}
\newcommand{\vv}{\vb{v}}
\newcommand{\vw}{\vb{w}}
\newcommand{\vx}{\vb{x}}
\newcommand{\vy}{\vb{y}}
\newcommand{\vz}{\vb{z}}
\newcommand{\vq}{\vb{q}}
\newcommand{\vp}{\vb{p}}
\newcommand{\vF}{\vb{F}}
\newcommand{\vP}{\vb{P}}
\newcommand{\vG}{\vb{G}}
\newcommand{\vQ}{\vb{Q}}

% Definition equality.
\newcommand{\defeq}{\overset{\mathrm{def}}{=}}

% Tensor symbols: bold sans-serif.
\newcommand{\tens}[1]{\boldsymbol{\mathsf{#1}}}

% Under-tilde notation (e.g. inertia tensor symbol).
\stackMath
\newcommand\tenq[2][1]{%
  \def\useanchorwidth{T}%
  \ifnum#1>1%
    \stackunder[0pt]{\tenq[\numexpr#1-1\relax]{#2}}{\scriptscriptstyle\sim}%
  \else%
    \stackunder[1pt]{#2}{\scriptscriptstyle\sim}%
  \fi%
}

% Real/imaginary parts as operators (override fraktur defaults).
\renewcommand{\Re}{\operatorname{Re}}
\renewcommand{\Im}{\operatorname{Im}}

% ===================== Streamlined margin notes =========================
% Tweaks (override before loading if you want)
\providecommand{\NoteFontSize}{\scriptsize}     % note text size
\providecommand{\NoteFont}{\itshape\sffamily}  % bold typewriter look
\providecommand{\NoteColor}{black}              % text color
\providecommand{\MarginNoteWidth}{3.2cm}        % box width

% Margin width
\setlength{\marginparwidth}{\MarginNoteWidth}

% Side-aware alignment helper
\newcommand{\NoteAlign}{%
  \checkoddpage
  \ifoddpage\raggedleftmarginnote\else\raggedrightmarginnote\fi
}

% Single \note command
\newcommand{\note}[1]{%
  \marginnote{%
    \NoteAlign
    \NoteFontSize
    \begin{minipage}{\MarginNoteWidth}%
      {\NoteFont\color{\NoteColor}#1}%
    \end{minipage}%
  }%
}
